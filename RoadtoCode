        function updateUILanguage() {
            try {
                const T = translations[currentLang];
                document.querySelectorAll('.translatable').forEach(el => { const key = el.getAttribute('data-key'); if (T[key]) el.textContent = T[key]; });
                renderCourses();
            } catch (e) { console.error("Error updating language", e); }
        }
        
        function renderCourses() {
            const progContainer = document.getElementById('programming-cards');
            const langContainer = document.getElementById('language-cards');
            if (!progContainer || !langContainer) return;
            progContainer.innerHTML = ''; langContainer.innerHTML = '';
            courses.forEach(course => {
                let logoHtml = '';
                if (course.icon && course.icon.startsWith('<')) logoHtml = `<div class="course-icon" style="background: ${course.color}">${course.icon}</div>`;
                else logoHtml = `<div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl font-bold" style="background: ${course.color}20">${course.flag || 'L'}</div>`;
                const html = `<div class="course-card bg-[var(--card)] rounded-2xl p-6 border border-[var(--border)]" onclick="openCourse('${course.id}')"><div class="flex items-center gap-3 mb-4">${logoHtml}<h3 class="font-display text-xl font-bold">${course.name}</h3></div><p class="text-sm text-[var(--fg-muted)] mb-4">30 unique lessons.</p><div class="text-xs text-[var(--accent)] font-semibold">Start &rarr;</div></div>`;
                if (course.type === 'programming') progContainer.innerHTML += html; else langContainer.innerHTML += html;
            });
        }
        
        function openCourse(courseId) {
            currentCourse = courses.find(c => c.id === courseId);
            if(!currentCourse) return;
            const T = translations[currentLang];
            let headerIcon = '';
            if (currentCourse.icon && currentCourse.icon.startsWith('<')) headerIcon = `<div class="w-16 h-16 rounded-2xl flex items-center justify-center overflow-hidden" style="background: ${currentCourse.color}">${currentCourse.icon}</div>`;
            else headerIcon = `<div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl font-bold" style="background: ${currentCourse.color}20">${currentCourse.flag || 'L'}</div>`;
            document.getElementById('course-header').innerHTML = `<button onclick="showView('landing')" class="flex items-center gap-2 text-[var(--fg-muted)] hover:text-[var(--accent)] mb-4">&larr; Back</button><div class="flex items-center gap-4">${headerIcon}<div><h1 class="font-display text-3xl font-bold">${currentCourse.name}</h1><p class="text-[var(--fg-muted)]">30 Lessons</p></div></div>`;
            
            let lessonsHtml = '';
            for (let i = 1; i <= 30; i++) {
                const isCompleted = completedLessons[`${courseId}-${i}`];
                const lessonPreview = generateLessonContent(courseId, i);
                if(!lessonPreview) continue;
                lessonsHtml += `<div class="lesson-item p-4 flex items-center justify-between cursor-pointer ${isCompleted ? 'completed' : ''}" onclick="openLesson(${i})"><div class="flex items-center gap-4"><div class="status-icon w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold ${isCompleted ? '' : 'bg-[var(--bg-alt)] text-[var(--fg-muted)]'}">${isCompleted ? '✓' : i}</div><div><h4 class="font-medium">${lessonPreview.title}</h4><span class="text-xs px-2 py-0.5 rounded-full ${lessonPreview.diffClass}">${lessonPreview.difficulty}</span></div></div><svg class="text-[var(--fg-muted)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></div>`;
            }
            document.getElementById('lessons-list').innerHTML = lessonsHtml;
            updateProgress(); showView('course');
        }

        function openLesson(lessonNum) {
            const data = generateLessonContent(currentCourse.id, lessonNum);
            if(!data) return;
            const T = translations[currentLang];
            let exercisesHtml = '';
            if (data.exercises && data.exercises.length > 0) {
                exercisesHtml = '<div class="mt-8 border-t border-[var(--border)] pt-6"><h3 class="font-bold mb-4">' + T.exercise + '</h3>';
                data.exercises.forEach((ex, i) => exercisesHtml += `<div class="exercise-box"><p class="mb-2">${ex.q}</p><div class="answer-box"><code>${ex.a}</code></div></div>`);
                exercisesHtml += '</div>';
            }

            let bodyContent = '';
            if (data.isProg) {
                bodyContent = `
                <div class="p-6">
                    <h3 class="font-bold text-lg mb-2">${T.code}</h3>
                    <div class="mb-6 lesson-text leading-relaxed">${data.content}</div>
                    ${data.tip ? `<div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6 text-sm"><strong>Tip:</strong> ${data.tip}</div>` : ''}
                    <div class="code-editor mb-2">
                        <div class="code-header"><span>${data.courseName} Code</span><span>Try on compiler</span></div>
                        <textarea class="code-area" spellcheck="false" readonly>${data.code}</textarea>
                        <div class="code-output"><span class="text-gray-400 mr-2">${T.output_label}:</span> ${data.output}</div>
                    </div>
                    ${exercisesHtml}
                </div>`;
            } else {
                bodyContent = `
                <div class="p-6">
                    <div class="mb-6 leading-relaxed">${data.content}</div>
                    <div class="vocab-card">
                        <div class="text-sm uppercase tracking-wider text-[var(--fg-muted)] mb-1">${currentCourse.name}</div>
                        <div class="vocab-word">${data.vocab.word}</div>
                        <div class="vocab-pron">/${data.vocab.pron}/</div>
                        <div class="vocab-trans"><strong>English:</strong> ${data.vocab.translation}</div>
                    </div>
                    ${exercisesHtml}
                </div>`;
            }

            document.getElementById('lesson-content').innerHTML = `
                <div class="p-6 border-b border-[var(--border)]"><span class="text-xs px-2 py-0.5 rounded-full ${data.diffClass}">${data.difficulty}</span><h2 class="font-display text-2xl font-bold mt-2">${data.title}</h2></div>
                ${bodyContent}
                <div class="p-6 bg-[var(--bg-alt)] flex items-center justify-between">
                    <button onclick="openLesson(${Math.max(1, lessonNum - 1)})" class="btn-secondary">${T.prev}</button>
                    <button onclick="completeLesson(${lessonNum})" class="btn-primary">${T.complete}</button>
                </div>`;
            showView('lesson');
        }

        // === SMART AI LOGIC ===
        function toggleAI() { isAIOpen = !isAIOpen; document.getElementById('ai-chat').classList.toggle('active', isAIOpen); }
        
        function switchAITab(tab) {
            document.querySelectorAll('.ai-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('ai-tab-chat').classList.toggle('hidden', tab !== 'chat');
            document.getElementById('ai-tab-translate').classList.toggle('hidden', tab !== 'translate');
        }

        function sendMessage() {
            const input = document.getElementById('ai-text').value.trim();
            if (!input) return;
            
            const container = document.getElementById('ai-messages');
            container.innerHTML += `<div class="ai-msg user">${input.replace(/</g, "&lt;")}</div>`;
            document.getElementById('ai-text').value = '';

            // Process Input
            let response = "";
            const lowerInput = input.toLowerCase();

            // 1. Code Detection (contains symbols)
            if (lowerInput.includes("{") || lowerInput.includes(";") || lowerInput.includes("print") || lowerInput.includes("()") || lowerInput.includes("cout") || lowerInput.includes("<")) {
                response = "Analyzing code...<br>";
                let errors = [];
                if(currentCourse && currentCourse.id === 'python') { if(lowerInput.includes('print ') && !lowerInput.includes('print(')) errors.push("Python 3 uses parentheses: print('text')"); }
                if(currentCourse && currentCourse.id === 'cpp') { if(!lowerInput.includes(';')) errors.push("Missing semicolon (;)?"); }
                if (errors.length === 0) response += "✅ Looks good!";
                else errors.forEach(e => response += "⚠️ " + e + "<br>");
            } 
            // 2. Translation Detection
            else if (lowerInput.startsWith("translate")) {
                // Try to extract word and language
                // Simple logic: "translate hello to spanish"
                const parts = lowerInput.split(" ");
                if (parts.length >= 4) {
                    const word = parts[1];
                    const langKey = parts[3]; // simplified
                    // Try to find in languageData
                    const langMap = { 'spanish': 'es', 'french': 'fr', 'arabic': 'ar', 'korean': 'ko', 'chinese': 'zh', 'japanese': 'ja', 'portuguese': 'pt', 'brazilian': 'pt-br' };
                    const code = langMap[langKey];
                    if (code && languageData[code] && languageData[code][word]) {
                        const data = languageData[code][word];
                        response = `<strong>Translation:</strong> ${data.w}<br><strong>Pronunciation:</strong> /${data.p}/`;
                    } else {
                        response = `I couldn't find "${word}" in my dictionary. Try the Translate tab!`;
                    }
                } else {
                    response = "Use format: translate [word] to [language]. Example: translate hello to spanish";
                }
            }
            // 3. Definition / Knowledge
            else if (lowerInput.startsWith("what is") || lowerInput.startsWith("explain")) {
                const term = lowerInput.replace("what is ", "").replace("explain ", "").replace("?", "");
                if (aiKnowledge[term]) {
                    response = aiKnowledge[term];
                } else {
                    response = `I don't have a specific definition for "${term}". Try asking about variables, loops, functions, or classes.`;
                }
            }
            // 4. Greetings
            else if (lowerInput === "hi" || lowerInput === "hello") {
                response = "Hello! I am your Smart Assistant. I can:<br>1. Check your code for errors.<br>2. Explain programming concepts (e.g., 'What is a variable?').<br>3. Translate words (e.g., 'Translate hello to Spanish').";
            }
            // 5. Fallback
            else {
                response = "I'm not sure how to help with that. You can ask me to check code, explain concepts, or translate words using the Translate tab.";
            }

            container.innerHTML += `<div class="ai-msg bot">${response}</div>`;
            container.scrollTop = container.scrollHeight;
        }

        function translateWord() {
            const word = document.getElementById('trans-word').value.toLowerCase();
            const code = document.getElementById('trans-lang').value;
            const resultDiv = document.getElementById('trans-result');
            
            if (languageData[code] && languageData[code][word]) {
                const data = languageData[code][word];
                document.getElementById('trans-word-res').textContent = data.w;
                document.getElementById('trans-pron-res').textContent = `/${data.p}/`;
                resultDiv.classList.remove('hidden');
            } else {
                document.getElementById('trans-word-res').textContent = "Word not found.";
                document.getElementById('trans-pron-res').textContent = "Try: Hello, Water, Thanks, Friend...";
                resultDiv.classList.remove('hidden');
            }
        }

        function completeLesson(lessonNum) { 
            completedLessons[`${currentCourse.id}-${lessonNum}`] = true; 
            if (lessonNum < 30) openLesson(lessonNum + 1); 
            else { alert("Congratulations!"); openCourse(currentCourse.id); } 
        }
        
        function updateProgress() { 
            let completed = 0; for (let i = 1; i <= 30; i++) { if (completedLessons[`${currentCourse.id}-${i}`]) completed++; } 
            document.getElementById('progress-text').textContent = `${completed} / 30`; 
            document.getElementById('progress-bar').style.width = `${(completed / 30) * 100}%`; 
        }

        // === SYSTEM ===
        function showView(v) { document.querySelectorAll('.view-section').forEach(e => e.classList.remove('active')); const target = document.getElementById(`${v}-view`); if(target) target.classList.add('active'); window.scrollTo(0,0); }
        function scrollToSection(id) { showView('landing'); setTimeout(() => document.getElementById(id).scrollIntoView({ behavior: 'smooth' }), 100); }
        function openModal(t) { document.getElementById('modal').classList.add('active'); document.getElementById('modal-title').textContent = translations[currentLang][t==='login'?'btn_login':'btn_signup']; document.getElementById('signup-form').classList.toggle('hidden', t==='login'); document.getElementById('login-form').classList.toggle('hidden', t!=='login'); }
        function closeModal(e) { if(!e || e.target.id==='modal') document.getElementById('modal').classList.remove('active'); }
        function toggleAuthForm(t) { document.getElementById('login-form').classList.toggle('hidden'); document.getElementById('signup-form').classList.toggle('hidden'); document.getElementById('modal-title').textContent = translations[currentLang][t==='login'?'btn_login':'btn_signup']; }
        function handleSubmit(e, t) { e.preventDefault(); isLoggedIn = true; document.getElementById('login-btn').style.display = 'none'; document.getElementById('signup-btn').textContent = "My Account"; closeModal(); }
        window.addEventListener('scroll', () => document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50));
        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", renderCourses); else renderCourses();
    </script>
</body
